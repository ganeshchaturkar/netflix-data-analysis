    "import pandas as pd\n",
    "import matplotlib.pyplot as plt\n",
    "import seaborn as sns\n",
    "\n",
    "# load dataset\n",
    "df = pd.read_csv(\"../data/netflix_titles.csv\")\n",
    "\n",
    "print(df.head())\n",
    "\n",
    "# movies vs tv shows\n",
    "sns.countplot(x=\"type\", data=df)\n",
    "plt.title(\"Movies vs TV Shows\")\n",
    "plt.show()"
   ]
